{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixpkgs": ["python311"]
        },
        "install": {
          "cmd": "pip install -r requirements.txt"
        }
      },
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "Always",
    "restartPolicyMaxRetries": 10,
    "healthCheckPath": "/health"
  }
}
